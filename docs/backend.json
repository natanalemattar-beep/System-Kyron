{
  "entities": {
    "DemoRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DemoRequest",
      "type": "object",
      "description": "Represents a high-fidelity request for a product demonstration.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "role": { "type": "string" },
        "companySize": { "type": "string" },
        "sector": { "type": "string" },
        "urgency": { "type": "string" },
        "module": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "demo_done", "closed"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "company", "module"]
    },
    "FinancialDocument": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FinancialDocument",
      "type": "object",
      "description": "Represents a financial document uploaded to the system.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "filename": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "documentType": { "type": "string" },
        "extractedData": { "type": "string" }
      },
      "required": ["id", "userId", "filename", "uploadDate", "documentType", "extractedData"]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents a financial transaction.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "financialDocumentId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["id", "userId", "financialDocumentId", "date", "description", "amount", "category"]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "description": "Represents an invoice.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" }
      },
      "required": ["id", "userId", "invoiceNumber", "issueDate", "dueDate", "amount", "status", "customerName", "customerEmail"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" }
      },
      "required": ["id", "email", "firstName", "lastName"]
    }
  },
  "auth": { "providers": ["password", "anonymous"] },
  "firestore": {
    "structure": [
      { "path": "/demoRequests/{requestId}", "definition": { "entityName": "DemoRequest", "schema": { "$ref": "#/backend/entities/DemoRequest" }, "description": "Respaldo digital de solicitudes de demo comerciales.", "params": [{ "name": "requestId", "description": "ID de la solicitud." }] } },
      { "path": "/users/{userId}", "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "Perfiles de usuario.", "params": [{ "name": "userId", "description": "UID del usuario." }] } }
    ]
  }
}