rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FINTRACK AUTOMATION SECURITY RULES
     * 
     * Core Philosophy: 
     * This ruleset implements a dual-layer security model. Individual user profiles are protected 
     * by a strict ownership model, while organizational data follows a collaborative, role-based 
     * shared access model. 
     * 
     * Data Structure:
     * - /users/{userId}: Private user profile data.
     * - /organizations/{organizationId}: Root for collaborative financial data.
     * - Subcollections (customers, invoices, etc.): Nested under organizations for logical grouping.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: Subcollection documents denormalize the organization's member list 
     *    to allow for faster authorization on single-document reads and writes.
     * 2. Strict Relational Integrity: On creation, documents must include IDs that match their 
     *    Firestore path to prevent data or ownership hijacking.
     * 3. Lookup-Based Listing: To comply with strict query security, list operations on subcollections 
     *    verify membership by looking up the parent organization document.
     * 4. Prototyping Flexibility: While access control is strict, the schema (fields like name, email, 
     *    balance) is not enforced to allow for rapid development.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks for existence and ownership for destructive operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the user is a member in an organization document's member map. */
    function isOrgMember(orgData) {
      return isSignedIn() && orgData.members[request.auth.uid] != null;
    }

    /** Checks if the user is a member of an organization by looking up the parent document. */
    function checkOrgAccess(orgId) {
      return isOrgMember(get(/databases/$(database)/documents/organizations/$(orgId)).data);
    }

    /** Validates that a field in the incoming data matches a path parameter. */
    function matchesPath(field, pathParam) {
      return request.resource.data[field] == pathParam;
    }

    /** Enforces immutability of a field during updates. */
    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profile documents.
     * @path /users/{userId}
     * @allow (create) if auth.uid matches userId and data.id matches userId.
     * @deny (read) if auth.uid does not match userId.
     * @principle Enforces path-based ownership and relational consistency for private data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && matchesPath('id', userId);
      allow update: if isExistingOwner(userId) && isImmutable('id');
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the root Organization documents.
     * @path /organizations/{organizationId}
     * @allow (get) if user is in the members map.
     * @deny (list) Top-level listing is restricted to prevent scanning all organizations.
     * @principle Uses a denormalized member map for shared access control.
     */
    match /organizations/{organizationId} {
      allow get: if isOrgMember(resource.data);
      allow list: if false; // Users should not list all organizations; query specific Orgs instead.
      allow create: if isSignedIn() && matchesPath('id', organizationId);
      allow update: if isOrgMember(resource.data) && isImmutable('id');
      allow delete: if isOrgMember(resource.data) && resource.data.members[request.auth.uid] == 'owner';
    }

    /**
     * @description Shared rules for organizational subcollections (Customers, Accounts, etc.).
     * @path /organizations/{organizationId}/[subcollection]/{documentId}
     * @allow (read) if user is a member of the organization.
     * @deny (write) if user is not an organization member.
     * @principle Uses parent-document lookup for list operations and local data for single-doc access.
     */
    match /organizations/{organizationId}/customers/{customerId} {
      allow get: if isOrgMember(resource.data.organizationMembers);
      allow list: if checkOrgAccess(organizationId);
      allow create: if checkOrgAccess(organizationId) && matchesPath('id', customerId) && matchesPath('organizationId', organizationId);
      allow update: if isOrgMember(resource.data.organizationMembers) && isImmutable('id') && isImmutable('organizationId');
      allow delete: if isOrgMember(resource.data.organizationMembers);
    }

    match /organizations/{organizationId}/financialAccounts/{accountId} {
      allow get: if isOrgMember(resource.data.organizationMembers);
      allow list: if checkOrgAccess(organizationId);
      allow create: if checkOrgAccess(organizationId) && matchesPath('id', accountId) && matchesPath('organizationId', organizationId);
      allow update: if isOrgMember(resource.data.organizationMembers) && isImmutable('id') && isImmutable('organizationId');
      allow delete: if isOrgMember(resource.data.organizationMembers);
    }

    match /organizations/{organizationId}/categories/{categoryId} {
      allow get: if isOrgMember(resource.data.organizationMembers);
      allow list: if checkOrgAccess(organizationId);
      allow create: if checkOrgAccess(organizationId) && matchesPath('id', categoryId) && matchesPath('organizationId', organizationId);
      allow update: if isOrgMember(resource.data.organizationMembers) && isImmutable('id') && isImmutable('organizationId');
      allow delete: if isOrgMember(resource.data.organizationMembers);
    }

    match /organizations/{organizationId}/transactions/{transactionId} {
      allow get: if isOrgMember(resource.data.organizationMembers);
      allow list: if checkOrgAccess(organizationId);
      allow create: if checkOrgAccess(organizationId) && matchesPath('id', transactionId) && matchesPath('organizationId', organizationId);
      allow update: if isOrgMember(resource.data.organizationMembers) && isImmutable('id') && isImmutable('organizationId');
      allow delete: if isOrgMember(resource.data.organizationMembers);
    }

    match /organizations/{organizationId}/invoices/{invoiceId} {
      allow get: if isOrgMember(resource.data.organizationMembers);
      allow list: if checkOrgAccess(organizationId);
      allow create: if checkOrgAccess(organizationId) && matchesPath('id', invoiceId) && matchesPath('organizationId', organizationId);
      allow update: if isOrgMember(resource.data.organizationMembers) && isImmutable('id') && isImmutable('organizationId');
      allow delete: if isOrgMember(resource.data.organizationMembers);

      /**
       * @description Line items nested under an invoice.
       * @path /organizations/{organizationId}/invoices/{invoiceId}/invoiceItems/{itemId}
       */
      match /invoiceItems/{itemId} {
        allow get: if isOrgMember(resource.data.organizationMembers);
        allow list: if checkOrgAccess(organizationId);
        allow create: if checkOrgAccess(organizationId) && matchesPath('id', itemId) && matchesPath('invoiceId', invoiceId);
        allow update: if isOrgMember(resource.data.organizationMembers) && isImmutable('id') && isImmutable('invoiceId');
        allow delete: if isOrgMember(resource.data.organizationMembers);
      }
    }

    match /organizations/{organizationId}/financialDocuments/{docId} {
      allow get: if isOrgMember(resource.data.organizationMembers);
      allow list: if checkOrgAccess(organizationId);
      allow create: if checkOrgAccess(organizationId) && matchesPath('id', docId) && matchesPath('organizationId', organizationId) && matchesPath('uploadedByUserId', request.auth.uid);
      allow update: if isOrgMember(resource.data.organizationMembers) && isImmutable('id') && isImmutable('organizationId');
      allow delete: if isOrgMember(resource.data.organizationMembers);
    }
  }
}