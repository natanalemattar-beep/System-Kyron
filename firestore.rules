rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FINTRACK AUTOMATION SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset enforces a strict User-Ownership model. All financial data is logically and 
     * physically siloed by the Firebase Authentication UID. Access is granted only if the 
     * authenticated user's UID matches the {userId} segment of the document path.
     *
     * Data Structure:
     * All data is hierarchically nested under /users/{userId}. 
     * Organizations are subcollections of a User, and all financial entities (Accounts, 
     * Transactions, Invoices, etc.) are subcollections of an Organization.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: To maximize performance and reliability, we rely on 
     *    path-based authorization. By nesting all resources under the owner's UID, 
     *    we avoid costly 'get()' lookups for parent documents.
     * 2. Denormalization for Integrity: While authorization is path-based, we enforce 
     *    that internal fields like 'ownerUserId' and 'organizationId' match the path 
     *    during creation to ensure data consistency for potential future administrative queries.
     * 3. Prototyping Flexibility: These rules strictly control WHO can access data, but 
     *    do NOT enforce the internal schema of the objects (e.g., field types or optionality), 
     *    allowing for rapid frontend iteration without breaking security.
     * 4. Destructive Operation Safety: Updates and Deletes explicitly verify document 
     *    existence (resource != null) to prevent unintended side effects on non-existent data.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines ownership check with a check for document existence. Used for updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Validates that the internal ID matches the path ID during creation. */
    function isDataConsistent(field, pathValue) {
      return request.resource.data[field] == pathValue;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents.
     * @path /users/{userId}
     * @allow (create) if auth.uid == userId (self-registration).
     * @deny (list) if auth.uid != userId (prevents user discovery).
     * @principle Self-creation and strict owner-only access.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isDataConsistent('id', userId);
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Rules for organizations owned by a user.
       * @path /users/{userId}/organizations/{organizationId}
       * @allow (get) if the userId in the path matches the authenticated user.
       * @deny (create) if the ownerUserId field does not match the userId in the path.
       * @principle Path-based ownership with denormalized relationship validation.
       */
      match /organizations/{organizationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isDataConsistent('ownerUserId', userId);
        allow update, delete: if isExistingOwner(userId);

        /**
         * @description Shared rule logic for organization sub-resources (Accounts, Categories, Contacts, Documents, Transactions, Invoices).
         * @path /users/{userId}/organizations/{organizationId}/[subcollection]/{id}
         * @principle Ensures all nested resources are consistently owned by the user and linked to the correct organization.
         */
        match /financialAccounts/{id} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent('organizationId', organizationId);
          allow update, delete: if isExistingOwner(userId);
        }

        match /categories/{id} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent('organizationId', organizationId);
          allow update, delete: if isExistingOwner(userId);
        }

        match /contacts/{id} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent('organizationId', organizationId);
          allow update, delete: if isExistingOwner(userId);
        }

        match /documents/{id} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent('organizationId', organizationId);
          allow update, delete: if isExistingOwner(userId);
        }

        match /transactions/{id} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent('organizationId', organizationId);
          allow update, delete: if isExistingOwner(userId);
        }

        match /invoices/{invoiceId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isDataConsistent('organizationId', organizationId);
          allow update, delete: if isExistingOwner(userId);

          /**
           * @description Rules for individual line items within an invoice.
           * @path /users/{userId}/organizations/{organizationId}/invoices/{invoiceId}/lineItems/{lineItemId}
           * @allow (list) if the authenticated user owns the parent hierarchy.
           * @deny (update) if the document does not exist or user is not the owner.
           * @principle Deeply nested relational integrity.
           */
          match /lineItems/{lineItemId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId) && isDataConsistent('invoiceId', invoiceId);
            allow update, delete: if isExistingOwner(userId);
          }
        }
      }
    }

    // Default deny for any paths not explicitly matched
    match /{document=**} {
      allow read, write: if false;
    }
  }
}