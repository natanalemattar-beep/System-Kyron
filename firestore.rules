rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FINTRACK AUTOMATION SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict User-Ownership model. Access is primarily determined 
     * by the document's location within the /users/{userId} hierarchy.
     * 
     * DATA STRUCTURE:
     * The database is organized hierarchically. All user-specific data, including accounts,
     * categories, transactions, documents, customers, and invoices, is nested under 
     * the specific user's root document.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Authorization: We rely on the {userId} wildcard in the path to 
     *    match the authenticated user's UID (request.auth.uid).
     * 2. Denormalization for Authorization: Essential relational fields (like userId and invoiceId) 
     *    are required to be present on the documents themselves. This allows for rapid 
     *    authorization checks without the need for additional get() calls.
     * 3. Prototyping Flexibility: While we strictly enforce who can access data, we do not 
     *    validate the full schema (types, optional fields) to allow for rapid iteration.
     * 4. Relational Integrity: On creation and update, we verify that the denormalized 
     *    UIDs in the document match the path wildcards to prevent data from being 
     *    "orphaned" or moved between users.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is made by an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines ownership check with a check that the resource actually exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for User profiles. Users can only access and manage their own profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid == "user123" and path is /users/user123
     * @deny (get) if auth.uid == "user456" but path is /users/user123
     * @principle Implements the Self-Creation and Ownership patterns.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for Financial Accounts. Owned by the user in the path.
       * @path /users/{userId}/accounts/{accountId}
       * @allow (update) if owner modifies their own bank account document.
       * @deny (create) if the userId field in the data does not match the path userId.
       * @principle Enforces path-based ownership and relational integrity for subcollections.
       */
      match /accounts/{accountId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == accountId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Transaction Categories.
       * @path /users/{userId}/categories/{categoryId}
       * @allow (list) owner retrieving their category list.
       * @deny (delete) if the category does not exist.
       * @principle Ensures private access to categorization settings.
       */
      match /categories/{categoryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == categoryId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Financial Transactions.
       * @path /users/{userId}/transactions/{transactionId}
       * @allow (create) if transaction is linked to the correct owning user.
       * @deny (update) if trying to change the userId of the transaction.
       * @principle Protects individual transaction records via denormalized ownership.
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == transactionId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Uploaded Documents (Receipts/Invoices).
       * @path /users/{userId}/documents/{documentId}
       * @allow (get) owner viewing their own document metadata.
       * @deny (write) if not signed in.
       * @principle Secure storage of sensitive financial document metadata.
       */
      match /documents/{documentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == documentId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Customer records.
       * @path /users/{userId}/customers/{customerId}
       * @allow (update) owner updating customer contact info.
       * @deny (list) non-owner trying to list customers.
       * @principle Restricts customer CRM data to the managing user.
       */
      match /customers/{customerId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == customerId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Invoices.
       * @path /users/{userId}/invoices/{invoiceId}
       * @allow (create) owner generating a new invoice.
       * @deny (delete) unauthorized users.
       * @principle Protects billing data through ownership and path wildcards.
       */
      match /invoices/{invoiceId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == invoiceId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for Line Items within an Invoice.
         * @path /users/{userId}/invoices/{invoiceId}/lineItems/{lineItemId}
         * @allow (create) if document contains matching userId and invoiceId.
         * @deny (update) if the parent invoiceId or userId is changed.
         * @principle Deeply nested authorization relying on double denormalization (userId + invoiceId).
         */
        match /lineItems/{lineItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.invoiceId == invoiceId && request.resource.data.id == lineItemId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.invoiceId == resource.data.invoiceId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}