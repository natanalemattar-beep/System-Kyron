modules = ["nodejs-20", "web", "nix", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0", "javascript_openai_ai_integrations:2.0.0", "outlook:1.0.0", "twilio:1.0.0", "google-calendar:1.0.0", "javascript_anthropic_ai_integrations:2.0.0", "google-mail:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
TWILIO_ACCOUNT_SID = "AC0168557ba863996fbac2466690001ab4"
TWILIO_AUTH_TOKEN = "d6b9174b83b84932842051c45dc527a8"
TWILIO_PHONE_NUMBER = "+584167312194"

[deployment]
run = ["npm", "run", "start"]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
